    <!-- SAVINGS CALCULATOR -->
    <section class="savings-calc">
        <div class="savings-calc-inner">
            <h2 class="section-title white">Savings <span>Calculator</span></h2>
            <div class="section-underline"></div>
            <p class="section-subtitle white">See how much your savings could grow with NovaTrust Bank.</p>

            <div class="calc-box">
                <div class="calc-inputs">
                    <div class="calc-group">
                        <label>Initial Deposit ($)</label>
                        <input type="number" id="calcDeposit" value="1000" min="10" class="calc-input">
                    </div>
                    <div class="calc-group">
                        <label>Monthly Contribution ($)</label>
                        <input type="number" id="calcMonthly" value="100" min="0" class="calc-input">
                    </div>
                    <div class="calc-group">
                        <label>Interest Rate (%)</label>
                        <input type="number" id="calcRate" value="4.2" min="0" step="0.1" class="calc-input">
                    </div>
                    <div class="calc-group">
                        <label>Time Period (Years)</label>
                        <input type="number" id="calcYears" value="5" min="1" max="30" class="calc-input">
                    </div>
                </div>
                <button class="btn-blue calc-btn" onclick="calculateSavings()">Calculate</button>
                <div class="calc-result" id="calcResult">
                    <div class="calc-result-item">
                        <span>Total Saved</span>
                        <h3 id="totalSaved">$0</h3>
                    </div>
                    <div class="calc-result-item">
                        <span>Interest Earned</span>
                        <h3 id="interestEarned">$0</h3>
                    </div>
                    <div class="calc-result-item">
                        <span>Final Balance</span>
                        <h3 id="finalBalance">$0</h3>
                    </div>
                </div>
            </div>
        </div>
    </section>

