    <!-- PROCESS SECTION -->
    <section class="process-section">
        <div class="process-inner">
            <h2 class="section-title white">Our Hiring <span>Process</span></h2>
            <div class="section-underline"></div>
            <p class="section-subtitle white">We keep our hiring process straightforward, transparent and respectful of your time.</p>

            <div class="process-steps">
                <div class="process-step">
                    <div class="process-number">01</div>
                    <h3>Apply Online</h3>
                    <p>Submit your application and CV through our online portal. We review every single application personally.</p>
                </div>
                <div class="process-arrow"><i class="fa-solid fa-arrow-right"></i></div>
                <div class="process-step">
                    <div class="process-number">02</div>
                    <h3>Initial Interview</h3>
                    <p>A short 30-minute video call with our HR team to learn more about you, your experience and your goals.</p>
                </div>
                <div class="process-arrow"><i class="fa-solid fa-arrow-right"></i></div>
                <div class="process-step">
                    <div class="process-number">03</div>
                    <h3>Technical Assessment</h3>
                    <p>A role-specific assessment or case study to help us understand your skills and how you approach challenges.</p>
                </div>
                <div class="process-arrow"><i class="fa-solid fa-arrow-right"></i></div>
                <div class="process-step">
                    <div class="process-number">04</div>
                    <h3>Final Interview</h3>
                    <p>Meet the team and senior leadership. We want you to get to know us just as much as we want to know you.</p>
                </div>
                <div class="process-arrow"><i class="fa-solid fa-arrow-right"></i></div>
                <div class="process-step">
                    <div class="process-number">05</div>
                    <h3>Offer & Onboarding</h3>
                    <p>Receive your offer letter and begin a structured onboarding programme to set you up for success from day one.</p>
                </div>
            </div>
        </div>
    </section>

